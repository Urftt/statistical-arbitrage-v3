# Bitvavo API Configuration
# Copy this file to .env and fill in your credentials
# Get your API keys from: https://bitvavo.com/en/account/api-keys

# API Keys (leave empty for read-only public data)
BITVAVO_API_KEY=
BITVAVO_API_SECRET=

# API Settings
BITVAVO_REST_URL=https://api.bitvavo.com/v2
BITVAVO_WS_URL=wss://ws.bitvavo.com/v2/

# Rate Limiting (requests per second)
RATE_LIMIT_PER_SECOND=10

# Data Collection Settings
DEFAULT_INTERVAL=1h  # Options: 1m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d
DEFAULT_LIMIT=1000   # Max candles per request (max 1440)

# PostgreSQL Database
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
